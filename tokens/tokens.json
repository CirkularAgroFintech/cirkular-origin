      "danger": { "$value": "#FF5C5C", "$type": "color" },
      "info": { "$value": "#05C0CA", "$type": "color" }
    }
  },
  "font": {
    "family": {
      "sans": { "$value": "Plus Jakarta Sans", "$type": "fontFamily" },
