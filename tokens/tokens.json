{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "color": {
    "forest": {
      "950": { "$value": "#131614", "$type": "color" },
      "900": { "$value": "#1A2B2D", "$type": "color", "$description": "Primary background" },
      "800": { "$value": "#23393B", "$type": "color", "$description": "Surface, cards, navs" },
      "700": { "$value": "#2E4A4D", "$type": "color" },
      "600": { "$value": "#3C5C5F", "$type": "color" },
      "500": { "$value": "#547073", "$type": "color" }
    },
    "lime": { "$value": "#C7FF00", "$type": "color", "$description": "Accent / CTA / KPI hits — reserve to ~3-5% of pixels" },
    "teal": { "$value": "#05C0CA", "$type": "color", "$description": "Brand secondary, links" },
    "purple": { "$value": "#7A00FF", "$type": "color", "$description": "Tertiary accent" },
    "white": { "$value": "#FFFFFF", "$type": "color" },
    "cream": { "$value": "#F4F1EA", "$type": "color", "$description": "Light background, print" },
    "semantic": {
      "success": { "$value": "#6BD96E", "$type": "color" },
